# ──────────────────────────────────────────────
# Termainer — Remote Connection Configuration
# ──────────────────────────────────────────────
# Two configuration methods:
#
# 1) config.yaml (recommended for multiple servers):
#    Create ~/.config/termainer/config.yaml:
#      servers:
#        - label: "Prod Web"
#          host: ec2-54-123-45-67.us-east-1.compute.amazonaws.com
#          user: ubuntu
#          key: ~/.ssh/production.pem
#          provider: docker
#
# 2) .env file (single server, quick setup):
#    cp .env.example .env
#    Edit .env with your server details, then run:
#      termainer
#
#    Or use CLI flags:
#      termainer --host 192.168.1.100 --ssh-user ubuntu --ssh-key ~/.ssh/key.pem

# ── Required ──────────────────────────────────
# Remote SSH host (IP or hostname)
# TERMAINER_REMOTE_HOST=ec2-54-123-45-67.us-east-1.compute.amazonaws.com

# ── Authentication ────────────────────────────
# SSH user (default: root)
# TERMAINER_REMOTE_USER=ubuntu

# Use EITHER key OR password (not both):
# TERMAINER_REMOTE_KEY_PATH=~/.ssh/production.pem
# TERMAINER_REMOTE_PASSWORD=

# ── Connection ────────────────────────────────
# SSH port (default: 22)
# TERMAINER_REMOTE_PORT=22

# ── Provider ──────────────────────────────────
# Container runtime on the remote host.
# Options: docker, kubernetes, podman, openshift
# If not set, auto-detection runs on the remote host.
# TERMAINER_REMOTE_PROVIDER=docker

# ── Language ──────────────────────────────────
# UI language (default: en, options: en, es)
# TERMAINER_LANG=en
